# Quest 29: The Code Breaker

secret_code = 42 #The correct number the user must guess
attempts = 3 #Maximum attempts allowed

for i in range(attempts):

* This runs the loop 3 times since attempts = 3
* i basically counts which attempt you're on.

guess = int(input("Guess the secret code: "))

* Asks the user to enter a number.
* int() converts the input into an integer.

if guess == secret_code:

* If the guess equals 42, prints a success message,and break which stops the loop immediately

remaining = attempts - (i + 1)
* Calculate how many tries left
* i + 1 because i starts at 0

print("Wrong! No more attempts. Game over!")

* This prints when no attempts are remaining.
